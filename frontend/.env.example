# URL base del backend (Litestar). En docker compose el frontend usa el
# nombre del servicio; en local, localhost:8000.
VITE_API_URL=http://localhost:8000

# Client ID de OAuth 2.0 de Google (tipo "Web application"), el mismo proyecto
# cuyo Client ID va como GOOGLE_CLIENT_ID en el backend. Necesario para que
# "Sign in with Google" funcione — sin esto el botón se muestra pero no hace
# nada (no-op + warning en consola).
VITE_GOOGLE_CLIENT_ID=
