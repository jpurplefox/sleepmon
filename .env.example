# Copiá a .env y ajustá si hace falta. Lo lee docker-compose.
POSTGRES_USER=sleepmon
POSTGRES_PASSWORD=sleepmon
POSTGRES_DB=sleepmon

# DSN que usa el backend (local, fuera de Docker). Dentro de compose se arma solo.
DATABASE_URL=postgresql://sleepmon:sleepmon@localhost:5432/sleepmon

# Base DEDICADA para los tests de integración (deben terminar en `_test`).
# Los tests la crean sola si no existe y truncan tablas SOLO acá, nunca en la de dev.
TEST_DATABASE_URL=postgresql://sleepmon:sleepmon@localhost:5432/sleepmon_test

# --- Autenticación (obligatorias: el backend NO arranca sin estas dos) ---

# Client ID de OAuth 2.0 de Google (tipo "Web application"). Debe ser el MISMO
# que VITE_GOOGLE_CLIENT_ID. Se usa como audience al verificar el ID token.
GOOGLE_CLIENT_ID=

# Secreto para firmar los JWT de sesión (HS256). Generalo con: openssl rand -hex 32
# Nunca lo compartas ni lo commitees.
JWT_SECRET=

# El mismo Client ID de Google, expuesto al frontend (Vite lo inyecta en build).
VITE_GOOGLE_CLIENT_ID=

# --- Autenticación (opcionales, tienen default) ---

# Cookie de refresh marcada Secure (default true). En dev sobre http://localhost
# poné false para que la cookie viaje y funcionen la renovación silenciosa y el logout.
COOKIE_SECURE=false

# Vida de los tokens en segundos. Defaults: access 15 min, refresh 30 días.
# ACCESS_TTL_SECONDS=900
# REFRESH_TTL_SECONDS=2592000
